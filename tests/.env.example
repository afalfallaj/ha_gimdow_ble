# Gimdow BLE test harness — credential template
# Copy this file to .env and fill in your values.
# All fields are optional: the script prompts for any missing values.

# BLE MAC address of the lock (AA:BB:CC:DD:EE:FF format)
GIMDOW_MAC=

# Tuya device credentials (Mode A — manual entry)
GIMDOW_UUID=
GIMDOW_LOCAL_KEY=
GIMDOW_DEVICE_ID=
GIMDOW_CATEGORY=jtmspro
GIMDOW_PRODUCT_ID=rlyxv7pe
GIMDOW_DEVICE_NAME=
GIMDOW_PRODUCT_MODEL=A1 PRO MAX
GIMDOW_PRODUCT_NAME=Gimdow Lock

# Tuya cloud credentials (Mode B — cloud fetch)
# Endpoint options:
#   https://openapi.tuyaus.com  (US / Americas)
#   https://openapi.tuyaeu.com  (Europe)
#   https://openapi.tuyacn.com  (China)
#   https://openapi.tuyain.com  (India)
GIMDOW_CLOUD_ENDPOINT=https://openapi.tuyaus.com
GIMDOW_CLOUD_ACCESS_ID=
GIMDOW_CLOUD_ACCESS_SECRET=
GIMDOW_CLOUD_USERNAME=
GIMDOW_CLOUD_PASSWORD=
GIMDOW_CLOUD_COUNTRY_CODE=1
# App type: smartlife (Smart Life app) or tuyaSmart (Tuya Smart app)
GIMDOW_CLOUD_APP_TYPE=smartlife
