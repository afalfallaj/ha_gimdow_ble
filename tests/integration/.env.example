# Gimdow BLE hardware test credentials
# Copy this file to .env and fill in your values.

# --- Manual credentials (required for all test runs) ---
GIMDOW_MAC=AA:BB:CC:DD:EE:FF       # BLE MAC address of your lock
GIMDOW_UUID=                        # Tuya device UUID
GIMDOW_LOCAL_KEY=                   # Tuya local_key (32 hex chars)
GIMDOW_DEVICE_ID=                   # Tuya device ID

# Optional device info (defaults work for A1 Pro Max)
GIMDOW_CATEGORY=jtmspro
GIMDOW_PRODUCT_ID=rlyxv7pe
GIMDOW_DEVICE_NAME=
GIMDOW_PRODUCT_MODEL=A1 PRO MAX
GIMDOW_PRODUCT_NAME=Gimdow Lock

# --- Cloud credentials (optional — use to fetch UUID/local_key automatically) ---
GIMDOW_CLOUD_ACCESS_ID=
GIMDOW_CLOUD_ACCESS_SECRET=
GIMDOW_CLOUD_USERNAME=
GIMDOW_CLOUD_PASSWORD=
GIMDOW_CLOUD_COUNTRY_CODE=1         # Phone country code (1 = USA, 44 = UK, 966 = SA, etc.)
